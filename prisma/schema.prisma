// SOLICITAÇÕES
// ============================================

model Request {
  id                 String            @id @default(cuid())
  title              String
  description        String?
  priority           WorkOrderPriority @default(NONE)
  status             RequestStatus     @default(PENDING)
  dueDate            DateTime?
  teamApprovalStatus String            @default("PENDING")
  approvedAt         DateTime?
  rejectionReason    String?
  convertToWorkOrder Boolean           @default(false)
  urgency            String?

  executionStartedAt   DateTime?
  executionCompletedAt DateTime?
  executionNotes       String?
  beforePhotoUrl       String?
  afterPhotoUrl        String?
  executionData        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assetId String?
  asset   Asset? @relation(fields: [assetId], references: [id])

  locationId String?
  location   Location? @relation("LocationRequests", fields: [locationId], references: [id])

  approvedById String?
  approvedBy   User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  assignedToId String?
  assignedTo   User? @relation("RequestAssignedTo", fields: [assignedToId], references: [id])

  createdById String?
  createdBy   User? @relation("CreatedBy", fields: [createdById], references: [id])

  teamId String?
  team   Team? @relation(fields: [teamId], references: [id])

  unitId String?
  unit   Location? @relation("UnitRequests", fields: [unitId], references: [id])

  workOrderId        String?    @unique
  generatedWorkOrder WorkOrder? @relation("GeneratedFromRequest")

  files File[]

  @@index([companyId])
  @@index([status])
  @@index([teamId])
  @@index([approvedById])
  @@index([assignedToId])
  @@index([status, assignedToId])
  @@index([createdById])
  @@index([companyId, unitId])
}

