  quantity     Int    @default(0)
  criticality  String @default("LOW")
  warrantyTime Int    @default(0)
  warrantyUnit String?

  assetId String
  asset   Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model AssetDowntime {
  id          String    @id @default(cuid())
  startDate   DateTime
  endDate     DateTime?
  duration    Int?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assetId String
  asset   Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

// ============================================
// PLANOS DE MANUTENÇÃO
// ============================================

model StandardMaintenancePlan {
  id              String   @id @default(cuid())
  sequence        Int
  name            String
  maintenanceTime Int
  timeUnit        String
  period          String
  priority        String   @default("ZZZ")
  stopsAsset      Boolean  @default(false)
  toleranceDays   Int      @default(0)
  trackingType    String   @default("TIME")
