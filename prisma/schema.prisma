  updatedAt       DateTime @updatedAt

  calendarId String?
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  familyId String
  family   AssetFamily @relation(fields: [familyId], references: [id])

  familyModelId String?
  familyModel   AssetFamilyModel? @relation(fields: [familyModelId], references: [id])

  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tasks StandardMaintenanceTask[]

  @@unique([familyId, familyModelId, serviceTypeId, sequence])
  @@index([companyId])
}

model StandardMaintenanceTask {
  id            String @id @default(cuid())
  taskCode      Int    @default(0)
  description   String
  order         Int    @default(0)
  executionTime Int?

  planId String
