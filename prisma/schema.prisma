// ============================================
// ORDENS DE SERVIÇO
// ============================================

model WorkOrderCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  workOrders WorkOrder[]

  @@index([companyId])
}

model WorkOrder {
  id           String            @id @default(cuid())
  customId     String?
  externalId   String?
  internalId   String?           @unique
  systemStatus SystemStatus      @default(OUT_OF_SYSTEM)
  type         WorkOrderType     @default(CORRECTIVE)
  title        String
  description  String?
  priority     WorkOrderPriority @default(NONE)
  status       WorkOrderStatus   @default(PENDING)
  dueDate      DateTime?
  completedOn  DateTime?
  estimatedDuration Int?
  actualDuration    Int?
  archived     Boolean           @default(false)
  feedback     String?

  maintenanceFrequency MaintenanceFrequency?
  frequencyValue       Int?
  lastExecutionDate    DateTime?
  nextExecutionDate    DateTime?

  // Novos campos Fase 1
  protheusCode            String?
  protheusMaintenancePlan String?
  plannedStartDate        DateTime?
  sequenceNumber          Int?
  osType                  OsType?
  laborCost               Float     @default(0)
  partsCost               Float     @default(0)
  thirdPartyCost          Float     @default(0)
  toolsCost               Float     @default(0)
  realStopStart           DateTime?
  realStopEnd             DateTime?
  realMaintenanceStart    DateTime?
  realMaintenanceEnd      DateTime?
  executionResources      Json?
  executionSteps          Json?
  generateCorrectiveOS    Boolean   @default(false)

  executionNotes String?
  beforePhotoUrl String?
  afterPhotoUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assetId String?
  asset   Asset? @relation(fields: [assetId], references: [id])

  locationId String?
  location   Location? @relation("LocationWorkOrders", fields: [locationId], references: [id])

  categoryId String?
  category   WorkOrderCategory? @relation(fields: [categoryId], references: [id])

  createdById String?
  createdBy   User? @relation("CreatedBy", fields: [createdById], references: [id])

  completedById String?
  completedBy   User? @relation("CompletedBy", fields: [completedById], references: [id])

  assignedToId String?
  assignedTo   User? @relation("AssignedToUser", fields: [assignedToId], references: [id])

  sourceRequestId String? @unique
  sourceRequest   Request? @relation("GeneratedFromRequest", fields: [sourceRequestId], references: [id])

  parentPreventiveMaintenanceId String?
  parentPreventiveMaintenance   PreventiveMaintenance? @relation(fields: [parentPreventiveMaintenanceId], references: [id])

  unitId String?
  unit   Location? @relation("UnitWorkOrders", fields: [unitId], references: [id])

  serviceTypeId String?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id])

  assetMaintenancePlanId String?
  assetMaintenancePlan   AssetMaintenancePlan? @relation(fields: [assetMaintenancePlanId], references: [id])

  maintenancePlanExecId String?
  maintenancePlanExec   MaintenancePlanExecution? @relation(fields: [maintenancePlanExecId], references: [id])

  assignedUsers   User[] @relation("WorkOrderAssignedUsers")
  assignedTeams   Team[] @relation("WorkOrderAssignedTeams")
  tasks           Task[]
  labors          Labor[]
  parts           WorkOrderPart[]
  additionalCosts AdditionalCost[]
  files           File[]
  scheduleItems   WorkOrderScheduleItem[]

  @@index([companyId])
  @@index([assetId])
  @@index([locationId])
  @@index([status])
  @@index([unitId])
  @@index([assignedToId])
  @@index([companyId, status])
  @@index([companyId, unitId])
}

model Task {
  id        String   @id @default(cuid())
  label     String
  notes     String?
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model Labor {
  id                 String   @id @default(cuid())
  timeCategory       String?
  duration           Int
  hourlyRate         Float    @default(0)
  includeToTotalCost Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@index([workOrderId])
  @@index([userId])
}

model AdditionalCost {
  id          String   @id @default(cuid())
  description String
  cost        Float
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

