generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  GESTOR
  PLANEJADOR
  MECANICO
  ELETRICISTA
  OPERADOR
  CONSTRUTOR_CIVIL
}

enum WorkOrderStatus {
  PENDING
  RELEASED
  IN_PROGRESS
  ON_HOLD
  COMPLETE
}

enum WorkOrderPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkOrderType {
  REACTIVE
  PREVENTIVE
  CORRECTIVE
  PREDICTIVE
}

enum OsType {
  PREVENTIVE_MANUAL
  CORRECTIVE_PLANNED
  CORRECTIVE_IMMEDIATE
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  CUSTOM
}

enum SystemStatus {
  IN_SYSTEM
  OUT_OF_SYSTEM
}

enum AssetStatus {
  OPERATIONAL
  DOWN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FailureType {
  RANDOM
  REPETITIVE
}

enum ProcessSector {
  ENERGIA
  MOAGEM_1
  MOAGEM_2
  MOAGEM_3
  EXPEDICAO_1
  EXPEDICAO_2
  ENSACADEIRA_2
  SECADOR
}

enum VariableType {
  ANALOG
  DIGITAL
  COUNTER
  SETPOINT
}

enum VariableUnit {
  NONE
  CELSIUS
  FAHRENHEIT
  PASCAL
  BAR
  PSI
  METER_SECOND
  LITER_HOUR
  KG_HOUR
  TON_HOUR
  AMPERE
  VOLT
  WATT
  KILOWATT
  KILOWATT_HOUR
  HERTZ
  RPM
  PERCENT
  BOOLEAN
}

enum AssetHistoryEventType {
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_STATUS_CHANGED
  WORK_ORDER_CREATED
  WORK_ORDER_STARTED
  WORK_ORDER_COMPLETED
  REQUEST_CREATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  FILE_UPLOADED
  FILE_DELETED
  PART_ADDED
  PART_REMOVED
  DOWNTIME_STARTED
  DOWNTIME_ENDED
  METER_READING
  CHECKLIST_COMPLETED
  MAINTENANCE_SCHEDULED
  NOTE_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  TECHNICAL_INFO_ADDED
  TIP_ADDED
  CUSTOM
}

enum AssetAttachmentCategory {
  MANUAL
  TECHNICAL_DOCUMENT
  DATASHEET
  DRAWING
  PHOTO
  VIDEO
  CERTIFICATE
  WARRANTY
  WORK_ORDER_DOC
  MAINTENANCE_REPORT
  INSPECTION_REPORT
  TIP
  PROCEDURE
  SAFETY
  OTHER
}

// ============================================
// PRODUTOS DO PORTAL (macro-módulos comerciais)
// ============================================

enum ProductSlug {
  CMMS
  GVP
  GPA
}

enum ProductStatus {
  ACTIVE
  COMING_SOON
  DISABLED
}

model Product {
  id          String        @id @default(cuid())
  slug        ProductSlug   @unique
  name        String
  description String?
  icon        String?
  order       Int           @default(0)
  status      ProductStatus @default(COMING_SOON)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  modules          Module[]
  companyProducts  CompanyProduct[]
}

model CompanyProduct {
  id          String   @id @default(cuid())
  enabled     Boolean  @default(true)
  activatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId])
  @@index([companyId])
  @@index([productId])
}

// ============================================
// FEATURES DO PORTAL (itens de navegação por produto)
// ============================================

model Module {
  id          String   @id @default(cuid())
  name        String   // Nome de exibição (ex: "Ordens de Serviço")
  slug        String   @unique // Identificador único (ex: "work-orders")
  description String?
  icon        String?  // Nome do ícone (Lucide)
  order       Int      @default(0) // Ordem no menu
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Produto ao qual esta feature pertence
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  companyModules CompanyModule[]
}

model CompanyModule {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleId])
  @@index([companyId])
  @@index([moduleId])
}

// ============================================
// CORE MODELS
// ============================================

model Company {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  website   String?
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Módulos e produtos habilitados para esta empresa
  companyModules         CompanyModule[]
  companyProducts        CompanyProduct[]

  // units removido — Location agora serve como unidade
  users                  User[]
  workOrders             WorkOrder[]
  assets                 Asset[]
  locations              Location[]
  parts                  Part[]
  vendors                Vendor[]
  customers              Customer[]
  teams                  Team[]
  meters                 Meter[]
  requests               Request[]
  purchaseOrders         PurchaseOrder[]
  preventiveMaintenances PreventiveMaintenance[]
  assetCategories        AssetCategory[]
  partCategories         PartCategory[]
  workOrderCategories    WorkOrderCategory[]
  failureAnalysisReports FailureAnalysisReport[]
  processVariables       ProcessVariable[]
  processReadings        ProcessReading[]
  processAlarms          ProcessAlarm[]
  processAlarmTriggers   ProcessAlarmTrigger[]
  processDataFiles       ProcessDataFile[]
  standardAssets         StandardAsset[]
  // Cadastros Básicos (compartilhados entre unidades)
  calendars              Calendar[]
  workCenters            WorkCenter[]
  costCenters            CostCenter[]
  assetFamilies          AssetFamily[]
  assetFamilyModels      AssetFamilyModel[]
  positions              Position[]
  jobTitles              JobTitle[]
  characteristics        Characteristic[]
  resources              Resource[]
  maintenanceTypes       MaintenanceType[]
  maintenanceAreas       MaintenanceArea[]
  serviceTypes           ServiceType[]
  genericTasks           GenericTask[]
  genericSteps           GenericStep[]
  counterTypes           CounterType[]
  // Planos e KPIs
  standardMaintenancePlans StandardMaintenancePlan[]
  assetMaintenancePlans    AssetMaintenancePlan[]
  maintenancePlanExecutions MaintenancePlanExecution[]
  workOrderSchedules       WorkOrderSchedule[]
  kpiIndicators            KpiIndicator[]
  kpiVariables             KpiVariable[]
}

// Unit foi removido — Localizações (Location) agora servem como unidades organizacionais.
// As colunas unitId em todas as tabelas agora referenciam Location(id).

model UserUnit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  unitId String
  unit   Location @relation("UnitMembers", fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([userId])
  @@index([unitId])
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  jobTitle          String?
  jobTitleId        String?
  username          String   @unique
  role              UserRole @default(MECANICO)
  image             String?
  rate              Float    @default(0)
  enabled           Boolean  @default(true)
  lastLogin         DateTime?
  protheusMatricula String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation("LocationUsers", fields: [locationId], references: [id])

  jobTitleRef JobTitle? @relation("UserJobTitle", fields: [jobTitleId], references: [id])

  unitId String?
  unit   Location? @relation("UnitUsers", fields: [unitId], references: [id])

  // Unidade ativa do usuário (última selecionada)
  activeUnitId String?
  activeUnit   Location? @relation("ActiveUnitUsers", fields: [activeUnitId], references: [id])

  // Relação N:N — unidades a que o usuário tem acesso
  userUnits UserUnit[]

  assignedWorkOrders         WorkOrder[]  @relation("WorkOrderAssignedUsers")
  directlyAssignedWorkOrders WorkOrder[]  @relation("AssignedToUser")
  createdWorkOrders          WorkOrder[]  @relation("CreatedBy")
  completedWorkOrders        WorkOrder[]  @relation("CompletedBy")
  primaryAssets              Asset[]      @relation("PrimaryUser")
  assignedAssets             Asset[]      @relation("AssetAssignedUsers")
  createdRequests            Request[]    @relation("CreatedBy")
  approvedRequests           Request[]    @relation("ApprovedBy")
  assignedRequests           Request[]    @relation("RequestAssignedTo")
  labors                     Labor[]
  teamMemberships            TeamMember[]
  ledTeams                   Team[]       @relation("TeamLeader")
  notifications              Notification[]
  createdRAFs                FailureAnalysisReport[] @relation("RAFCreatedBy")
  createdSchedules           WorkOrderSchedule[]     @relation("ScheduleCreatedBy")
  resources                  Resource[]              @relation("UserResources")

  calendarId String?
  calendar   Calendar? @relation("UserCalendar", fields: [calendarId], references: [id])

  @@index([companyId])
  @@index([email])
  @@index([jobTitleId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  leaderId String?
  leader   User? @relation("TeamLeader", fields: [leaderId], references: [id])

  members            TeamMember[]
  assignedWorkOrders WorkOrder[] @relation("WorkOrderAssignedTeams")
  assignedAssets     Asset[]     @relation("AssetAssignedTeams")
  requests           Request[]

  @@index([companyId])
  @@index([leaderId])
}

model TeamMember {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Location?  @relation("ChildLocations", fields: [parentId], references: [id])
  children Location[] @relation("ChildLocations")

  // Relações via locationId
  assets     Asset[]     @relation("LocationAssets")
  workOrders WorkOrder[] @relation("LocationWorkOrders")
  requests   Request[]   @relation("LocationRequests")
  users      User[]      @relation("LocationUsers")

  // Relações via unitId (Location como unidade organizacional)
  unitAssets             Asset[]                   @relation("UnitAssets")
  unitWorkOrders         WorkOrder[]               @relation("UnitWorkOrders")
  unitRequests           Request[]                 @relation("UnitRequests")
  unitUsers              User[]                    @relation("UnitUsers")
  activeUnitUsers        User[]                    @relation("ActiveUnitUsers")
  unitMembers            UserUnit[]                @relation("UnitMembers")
  areas                  Area[]
  workCenters            WorkCenter[]
  rafs                   FailureAnalysisReport[]
  maintenancePlanExecutions MaintenancePlanExecution[]
  workOrderSchedules     WorkOrderSchedule[]

  @@index([companyId])
}

// ============================================
// CADASTROS BÁSICOS
// ============================================

model Calendar {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String   @default("WORK")
  workDays     Json?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  standardMaintenancePlans StandardMaintenancePlan[]
  assetMaintenancePlans    AssetMaintenancePlan[]
  workCenters              WorkCenter[]
  resources                Resource[]
  users                    User[]     @relation("UserCalendar")

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model Area {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unitId String
  unit   Location @relation(fields: [unitId], references: [id], onDelete: Cascade)

  workCenters WorkCenter[]
  assets      Asset[]

  @@index([unitId])
}

model CostCenter {
  id           String   @id @default(cuid())
  code         String
  name         String
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  workCenters WorkCenter[]
  assets      Asset[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model WorkCenter {
  id           String   @id @default(cuid())
  name         String
  description  String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  calendarId String?
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  areaId String?
  area   Area? @relation(fields: [areaId], references: [id])

  unitId String
  unit   Location @relation(fields: [unitId], references: [id], onDelete: Cascade)

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assets Asset[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
  @@index([unitId])
}

model AssetFamily {
  id           String   @id @default(cuid())
  code         String
  name         String
  protheusCode String?
  familyType   String   @default("BEM")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  modelMappings            AssetFamilyModelMapping[]
  assets                   Asset[]
  standardMaintenancePlans StandardMaintenancePlan[]
  standardAssets           StandardAsset[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model AssetFamilyModel {
  id           String   @id @default(cuid())
  name         String
  description  String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  familyMappings           AssetFamilyModelMapping[]
  assets                   Asset[]
  standardMaintenancePlans StandardMaintenancePlan[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model AssetFamilyModelMapping {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  familyId String
  family   AssetFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)

  modelId String
  model   AssetFamilyModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([familyId, modelId])
  @@index([familyId])
  @@index([modelId])
}

model Position {
  id           String   @id @default(cuid())
  name         String
  description  String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assets Asset[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model JobTitle {
  id           String   @id @default(cuid())
  name         String
  description  String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  users User[] @relation("UserJobTitle")

  @@unique([companyId, name])
  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model Characteristic {
  id           String   @id @default(cuid())
  name         String
  infoType     String   @default("Caractere")
  unit         String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  values AssetCharacteristicValue[]
  standardAssetValues StandardAssetCharacteristic[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model Resource {
  id           String   @id @default(cuid())
  name         String
  type         String
  unit           String?
  unitCost       Float    @default(0)
  availableCount Int?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("UserResources", fields: [userId], references: [id], onDelete: SetNull)

  calendarId String?
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  standardTaskResources StandardMaintenanceTaskResource[]
  assetTaskResources    AssetMaintenanceTaskResource[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
  @@index([userId])
}

model MaintenanceType {
  id             String   @id @default(cuid())
  name           String
  characteristic String?
  protheusCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  serviceTypes          ServiceType[]
  assetMaintenancePlans AssetMaintenancePlan[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model MaintenanceArea {
  id           String   @id @default(cuid())
  name         String
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  serviceTypes          ServiceType[]
  assetMaintenancePlans AssetMaintenancePlan[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model CounterType {
  id           String   @id @default(cuid())
  name         String
  description  String?
  protheusCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model ServiceType {
  id            String   @id @default(cuid())
  code          String
  name          String
  isLubrication Boolean  @default(false)
  protheusCode  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  maintenanceTypeId String
  maintenanceType   MaintenanceType @relation(fields: [maintenanceTypeId], references: [id])

  maintenanceAreaId String
  maintenanceArea   MaintenanceArea @relation(fields: [maintenanceAreaId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  standardMaintenancePlans StandardMaintenancePlan[]
  assetMaintenancePlans    AssetMaintenancePlan[]
  workOrders               WorkOrder[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model GenericTask {
  id             String   @id @default(cuid())
  code           Int
  name           String
  characteristic String?
  protheusCode   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model GenericStep {
  id                String   @id @default(cuid())
  name              String
  optionType        String   @default("NONE")
  averageTime       String?
  protheusCode      String?
  maintenanceAreaId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  standardTaskSteps StandardMaintenanceTaskStep[]
  assetTaskSteps    AssetMaintenanceTaskStep[]
  options           GenericStepOption[]

  @@unique([companyId, protheusCode])
  @@index([companyId])
}

model GenericStepOption {
  id    String @id @default(cuid())
  label String
  order Int    @default(0)

  stepId String
  step   GenericStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
}

// ============================================
// ASSETS
// ============================================

model AssetCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assets Asset[]

  @@index([companyId])
}

model Asset {
  id              String      @id @default(cuid())
  customId        String?
  name            String
  description     String?
  barCode         String?
  nfcId           String?
  area            String?
  acquisitionCost Float?
  image           String?
  status          AssetStatus @default(OPERATIONAL)
  archived        Boolean     @default(false)
  gutGravity      Int         @default(1)
  gutUrgency      Int         @default(1)
  gutTendency     Int         @default(1)

  // Campos TOTVS (ST9 - Tabela Bem)
  tag               String?   @db.VarChar(6)
  protheusCode      String?
  hasStructure      Boolean   @default(false)
  hasCounter        Boolean   @default(false)
  maintenanceStatus String    @default("ACTIVE")
  assetCategoryType String    @default("BEM")
  assetPriority     String?
  hourlyCost        Float     @default(0)
  manufacturer      String?
  modelName         String?
  serialNumber      String?
  purchaseDate      DateTime?

  // Campos adicionais TOTVS (Fase Integração)
  fixedAssetCode    String?   // Imobilizado (código contábil)
  assetPlate        String?   // Chapa Imobilizado
  ownershipType     String    @default("PROPRIO") // Próprio/Terceiro
  supplierCode      String?   // Código do Fornecedor
  supplierStore     String?   // Loja do Fornecedor
  warrantyPeriod    Int?      // Prazo de Garantia
  warrantyUnit      String?   // Unidade da Garantia (DIAS/MESES/ANOS)
  warrantyDate      DateTime? // Data fim da Garantia
  counterType       String?   // Tipo do Contador
  counterPosition   Float?    // Posição atual do Contador
  counterLimit      Float?    // Limite do Contador
  dailyVariation    Float?    // Variação diária do Contador
  accumulatedCounter Float?   // Contador Acumulado
  lifeValue         Float?    // Valor Vida Útil
  lifeUnit          String?   // Unidade Vida Útil
  purchaseValue     Float?    // Valor de Compra
  installationDate  DateTime? // Data de Instalação
  deactivationDate  DateTime? // Data de Baixa
  deactivationReason String?  // Motivo da Baixa
  warehouse         String?   // Almoxarifado
  shiftCode         String?   // Turno de Trabalho

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  locationId String?
  location   Location? @relation("LocationAssets", fields: [locationId], references: [id])

  categoryId String?
  category   AssetCategory? @relation(fields: [categoryId], references: [id])

  primaryUserId String?
  primaryUser   User? @relation("PrimaryUser", fields: [primaryUserId], references: [id])

  parentAssetId String?
  parentAsset   Asset?  @relation("ChildAssets", fields: [parentAssetId], references: [id])
  childAssets   Asset[] @relation("ChildAssets")

  unitId String?
  unit   Location? @relation("UnitAssets", fields: [unitId], references: [id])

  areaId String?
  assetArea Area? @relation(fields: [areaId], references: [id])

  workCenterId String?
  workCenter   WorkCenter? @relation(fields: [workCenterId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  familyId String?
  family   AssetFamily? @relation(fields: [familyId], references: [id])

  familyModelId String?
  familyModel   AssetFamilyModel? @relation(fields: [familyModelId], references: [id])

  assignedUsers          User[]                    @relation("AssetAssignedUsers")
  assignedTeams          Team[]                    @relation("AssetAssignedTeams")
  workOrders             WorkOrder[]
  requests               Request[]
  meters                 Meter[]
  downtimes              AssetDowntime[]
  parts                  AssetPart[]
  files                  File[]
  history                AssetHistory[]
  attachments            AssetAttachment[]
  characteristicValues   AssetCharacteristicValue[]
  sparePartsList         AssetSparePart[]
  maintenancePlans       AssetMaintenancePlan[]

  @@unique([unitId, tag])
  @@unique([unitId, protheusCode])
  @@index([companyId])
  @@index([locationId])
  @@index([categoryId])
  @@index([unitId])
  @@index([companyId, archived])
  @@index([parentAssetId])
}

model AssetCharacteristicValue {
  id       String @id @default(cuid())
  value    String
  unit     String?
  operator String @default("EQUAL")

  assetId String
  asset   Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  characteristicId String
  characteristic   Characteristic @relation(fields: [characteristicId], references: [id])

  @@unique([assetId, characteristicId])
  @@index([assetId])
}

model AssetSparePart {
