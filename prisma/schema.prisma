}

model StandardMaintenanceTaskResource {
  id               String  @id @default(cuid())
  resourceCount    Float   @default(1)
  quantity         Float   @default(0)
  unit             String  @default("H")
  generatesReserve Boolean @default(true)

  taskId String
  task   StandardMaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
}

model AssetMaintenancePlan {
  id                  String    @id @default(cuid())
  sequence            Int
  name                String?
  isStandard          Boolean   @default(false)
  standardPlanId      String?
  standardSequence    Int?
  lastMaintenanceDate DateTime?
  maintenanceTime     Int?
  timeUnit            String?
  period              String?
  isActive            Boolean   @default(true)
  toleranceDays       Int       @default(0)
  considerPlanning    Boolean   @default(true)
  trackingType        String    @default("TIME")
  protheusCode        String?
