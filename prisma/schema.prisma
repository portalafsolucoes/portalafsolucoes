  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])

  maintenanceAreaId String?
  maintenanceArea   MaintenanceArea? @relation(fields: [maintenanceAreaId], references: [id])

  maintenanceTypeId String?
  maintenanceType   MaintenanceType? @relation(fields: [maintenanceTypeId], references: [id])

  calendarId String?
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tasks      AssetMaintenanceTask[]
  workOrders WorkOrder[]

  @@unique([assetId, serviceTypeId, sequence])
  @@index([companyId])
  @@index([assetId])
}

model AssetMaintenanceTask {
  id            String  @id @default(cuid())
  taskCode      Int     @default(0)
  description   String
  order         Int     @default(0)
  executionTime Int?
  isActive      Boolean @default(true)

  planId String
  plan   AssetMaintenancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  steps     AssetMaintenanceTaskStep[]
  resources AssetMaintenanceTaskResource[]
}

model AssetMaintenanceTaskStep {
  id    String @id @default(cuid())
  order Int    @default(0)

  taskId String
  task   AssetMaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  stepId String
  step   GenericStep @relation(fields: [stepId], references: [id])
}

model AssetMaintenanceTaskResource {
  id               String  @id @default(cuid())
  resourceCount    Float   @default(1)
  quantity         Float   @default(0)
  unit             String  @default("H")
  generatesReserve Boolean @default(true)

  taskId String
  task   AssetMaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
}

