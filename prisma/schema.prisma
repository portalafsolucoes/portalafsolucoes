// ============================================
// GEP - GERENCIAMENTO DE VARIÁVEIS DE PROCESSO
// ============================================

model ProcessVariable {
  id          String       @id @default(cuid())
  sector      ProcessSector
  tagName     String
  description String
  type        VariableType @default(ANALOG)
  unit        VariableUnit @default(NONE)
  position    Int
  minValue    Float?
  maxValue    Float?
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  readings ProcessReading[]
  alarms   ProcessAlarm[]

  @@unique([companyId, sector, tagName])
  @@index([companyId])
  @@index([sector])
  @@index([tagName])
}

model ProcessReading {
  id        String   @id @default(cuid())
  timestamp DateTime
  value     Float
  createdAt DateTime @default(now())

  variableId String
  variable   ProcessVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([variableId])
  @@index([timestamp])
  @@index([companyId])
  @@index([variableId, timestamp])
}

model ProcessAlarm {
  id          String            @id @default(cuid())
  name        String
  description String?
  condition   String
  priority    WorkOrderPriority @default(MEDIUM)
  enabled     Boolean           @default(true)
  emailNotify Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  variableId String
  variable   ProcessVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  triggers ProcessAlarmTrigger[]

  @@index([companyId])
  @@index([variableId])
  @@index([enabled])
}

model ProcessAlarmTrigger {
  id          String    @id @default(cuid())
  triggeredAt DateTime  @default(now())
  value       Float
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  notes       String?

  alarmId String
  alarm   ProcessAlarm @relation(fields: [alarmId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([alarmId])
  @@index([companyId])
  @@index([triggeredAt])
}

// ============================================
// ASSET ATTACHMENTS E HISTORY
// ============================================

model AssetAttachment {
  id          String                  @id @default(cuid())
  name        String
  description String?
  category    AssetAttachmentCategory
  url         String
  mimeType    String?
  size        Int?
  version     String?
  tags        String[]
  isPublic    Boolean                 @default(false)
  expiresAt   DateTime?
  metadata    Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  assetId      String
  asset        Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  uploadedById String?

  @@index([assetId])
  @@index([category])
  @@index([createdAt])
  @@index([assetId, category])
}

model AssetHistory {
  id          String                @id @default(cuid())
  eventType   AssetHistoryEventType
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime              @default(now())

  assetId     String
  asset       Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  workOrderId String?
  requestId   String?
  fileId      String?
  userId      String?

  @@index([assetId])
  @@index([eventType])
  @@index([createdAt])
  @@index([assetId, createdAt])
}

model ProcessDataFile {
  id          String        @id @default(cuid())
  fileName    String
  sector      ProcessSector
  fileDate    DateTime
  recordCount Int
  fileSize    Int?
  importedAt  DateTime      @default(now())
  importedBy  String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fileName])
  @@index([companyId])
  @@index([sector])
  @@index([fileDate])
}

model StandardAsset {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relação com Família (chave de ligação)
  familyId String   @unique
  family   AssetFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Campos padrão (26 campos da tabela TP9 do Protheus)
  name            String?  // Nome
  costCenterCode  String?  // Centro Custo
  costCenterName  String?  // Nome C.Custo
  shiftCode       String?  // Turno
  workCenterCode  String?  // C.Trabalho
  workCenterName  String?  // Nome C. Tr.
  supplierCode    String?  // Fornecedor
  supplierStore   String?  // Loja
  modelType       String?  // Tipo Modelo
  manufacturer    String?  // Fabricante
  modelName       String?  // Modelo
  serialNumber    String?  // Serie
  warehouse       String?  // Estoque
  priority        String?  // Prioridade
  hourlyCost      Float?   // Custo Hora
  hasCounter      Boolean  @default(false) // Tem Contador
  assetMovement   String?  // Movim. Bem
  trackingPeriod  String?  // Per. Acomp.
  unitOfMeasure   String?  // Unid. Medida
  imageUrl        String?  // Imagem
  counterType     String?  // Tp. Contador
  coupling        String?  // Acoplamento
  annualCoupValue Float?   // Val. Ac. Ano

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  characteristics StandardAssetCharacteristic[]

  @@index([companyId])
  @@index([familyId])
}

model StandardAssetCharacteristic {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  standardAssetId  String
  standardAsset    StandardAsset @relation(fields: [standardAssetId], references: [id], onDelete: Cascade)

  characteristicId String
  characteristic   Characteristic @relation(fields: [characteristicId], references: [id], onDelete: Cascade)

  value            String
  unit             String?

  @@unique([standardAssetId, characteristicId])
  @@index([standardAssetId])
}
